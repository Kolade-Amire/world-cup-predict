# Postgres connection string from Railway (Postgres plugin -> Connect -> Postgres Connection URL)
DATABASE_URL="postgresql://user:password@host:port/railway"

# Long random string used to sign login cookies. Generate with:  openssl rand -base64 32
SESSION_SECRET="change-me-to-a-long-random-string"

# Password you type to access the /admin page (enter fixtures + results)
ADMIN_PASSWORD="pick-a-strong-admin-password"

# football-data.org API token for auto-syncing fixtures/times/results + squads.
# Free tier: https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY="your-token-here"

# apifootball.com API key — used only to auto-fill goal scorers (World Cup = league_id 28).
# Get one at https://apifootball.com  (regenerate if it ever leaks)
APIFOOTBALL_API_KEY="your-apifootball-key"

# Shared secret protecting the /api/cron/sync resync endpoint (Vercel Cron + GitHub Actions).
# Generate with:  openssl rand -base64 32
CRON_SECRET="another-long-random-string"
